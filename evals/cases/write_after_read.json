{
  "id": "write_after_read",
  "description": "读取后覆盖已有文件",
  "tags": ["write", "read-before-write"],
  "prompt": "覆盖 config.txt",
  "permission_mode": "accept_edits",
  "workspace_files": {
    "config.txt": "mode=old\n"
  },
  "expected_files": {
    "config.txt": {
      "equals": "mode=new\n"
    }
  },
  "max_tool_calls": 3,
  "fake_script": [
    {
      "text": "先读取。",
      "tool": "read_file",
      "input": {
        "file_path": "config.txt"
      }
    },
    {
      "text": "覆盖文件。",
      "tool": "write_file",
      "input": {
        "file_path": "config.txt",
        "content": "mode=new\n"
      }
    },
    "覆盖完成。"
  ]
}
